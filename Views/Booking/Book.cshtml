@model PBL3_Hotel_System.ViewModels.BookViewModel;
@{
    Layout = "_CleanLayout";
    ViewData["Title"] = "Xác nhận đặt phòng - Hotel Vip";
}

<style>
    body {
        background-color: #f4f7f6;
    }

    .booking-wrapper {
        max-width: 1100px;
        margin: 4rem auto;
        padding: 0 20px;
    }

    /* Header trang */
    .page-header {
        text-align: center;
        margin-bottom: 3rem;
    }

        .page-header h2 {
            font-family: var(--font-heading);
            font-size: 2.5rem;
            color: var(--secondary-color);
            margin-bottom: 10px;
        }

        .page-header p {
            color: var(--text-light);
        }

    /* Layout 2 cột */
    .booking-grid {
        display: grid;
        grid-template-columns: 1fr 1.6fr;
        gap: 30px;
        align-items: start;
    }

    /* CỘT TRÁI: THÔNG TIN PHÒNG */
    .room-summary-card {
        background: var(--bg-white);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-light);
        position: sticky;
        top: 20px; /* Cuộn trang nhưng card bên trái đứng im */
    }

    .room-summary-img {
        width: 100%;
        height: 250px;
        object-fit: cover;
    }

    .room-summary-body {
        padding: 25px;
    }

        .room-summary-body h3 {
            font-family: var(--font-heading);
            font-size: 1.5rem;
            margin-bottom: 15px;
        }

    .room-badges {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .badge {
        background: #f0f0f0;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        color: var(--text-main);
        font-weight: 500;
    }

        .badge i {
            color: var(--primary-color);
            margin-right: 5px;
        }

    .price-box {
        border-top: 1px dashed var(--border-color);
        margin-top: 20px;
        padding-top: 20px;
    }

        .price-box span {
            font-size: 0.9rem;
            color: var(--text-light);
        }

        .price-box h4 {
            color: #dc3545;
            font-size: 1.8rem;
            margin-top: 5px;
        }

    /* CỘT PHẢI: FORM NHẬP LIỆU */
    .booking-form-card {
        background: var(--bg-white);
        padding: 40px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-light);
    }

    .section-title {
        font-family: var(--font-heading);
        font-size: 1.3rem;
        margin-bottom: 20px;
        color: var(--secondary-color);
        border-bottom: 2px solid var(--primary-color);
        padding-bottom: 10px;
        display: inline-block;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .input-group label {
        display: block;
        font-weight: 500;
        margin-bottom: 8px;
        color: var(--text-main);
        font-size: 0.95rem;
    }

    .input-group input, .input-group textarea {
        width: 100%;
        padding: 12px 15px;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-family: var(--font-body);
        transition: var(--transition-fast);
        outline: none;
    }

        .input-group input:focus, .input-group textarea:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
        }

    /* HÓA ĐƠN TẠM TÍNH (RECEIPT) */
    .receipt-box {
        background: #fafafa;
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        padding: 25px;
        margin: 30px 0;
    }

    .receipt-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
        color: var(--text-main);
    }

    .receipt-total {
        border-top: 1px solid #ddd;
        padding-top: 15px;
        margin-top: 5px;
        font-weight: 700;
        font-size: 1.3rem;
        color: var(--secondary-color);
    }

    .btn-submit {
        background: var(--primary-color);
        color: white;
        border: none;
        width: 100%;
        padding: 16px;
        font-size: 1.1rem;
        font-weight: 600;
        border-radius: var(--radius-md);
        cursor: pointer;
        transition: var(--transition-fast);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-submit:hover {
            background: var(--primary-hover);
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(212, 175, 55, 0.4);
        }

    @@media (max-width: 992px) {
        .booking-grid {
            grid-template-columns: 1fr;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .room-summary-card {
            position: relative;
            top: 0;
        }
    }
</style>

<div class="booking-wrapper">

    <div class="page-header">
        <h2>Hoàn Tất Đặt Phòng</h2>
        <p>Vui lòng kiểm tra thông tin và chọn ngày lưu trú</p>
    </div>

    <div class="booking-grid">

        <!-- CỘT TRÁI: THÔNG TIN PHÒNG (Dạng Card dọc) -->
        <div class="room-summary-card">
            <!-- Nếu có link ảnh thì hiện, không thì hiện ảnh mặc định -->
            <img src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80" class="room-summary-img" alt="Phòng @Model.SoPhong" />

            <div class="room-summary-body">
                <h3>Phòng @Model.SoPhong</h3>

                <div class="room-badges">
                    <span class="badge"><i class="fas fa-star"></i> Hạng: @Model.LoaiPhong</span>
                    <span class="badge"><i class="fas fa-user-friends"></i> @Model.Size người lớn</span>
                    <span class="badge"><i class="fas fa-wifi"></i> Wifi miễn phí</span>
                </div>

                <p style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
                    Bạn đang đặt một trong những căn phòng tiện nghi nhất của Hotel Vip với tầm nhìn thoáng đãng và dịch vụ dọn phòng 24/7.
                </p>

                <div class="price-box">
                    <span>Giá mỗi đêm</span>
                    <h4 id="price-per-night" data-price="@Model.GiaPhong">@Model.GiaPhong.ToString("N0") ₫</h4>
                </div>
            </div>
        </div>

        <!-- CỘT PHẢI: FORM ĐẶT PHÒNG -->
        <div class="booking-form-card">
            <form asp-controller="Booking" asp-action="Confirm" method="post">
                <input type="hidden" asp-for="SoPhong" />

                <!-- SECTION 1: Lịch trình -->
                <h4 class="section-title">1. Lịch trình lưu trú</h4>
                <div class="form-row">
                    <div class="input-group">
                        <label asp-for="CheckIn"><i class="far fa-calendar-check"></i> Ngày nhận phòng</label>
                        <input asp-for="CheckIn" id="checkIn" min="2026-01-01" max="9999-12-31"  class="form-control" required />
                    </div>
                    <div class="input-group">
                        <label asp-for="CheckOut"><i class="far fa-calendar-times"></i> Ngày trả phòng</label>
                        <input asp-for="CheckOut" id="checkOut" min="2026-01-01" max="9999-12-31" class="form-control" required />
                    </div>
                </div>

                <!-- SECTION 2: Yêu cầu thêm (Câu hỏi của bạn) -->
                <h4 class="section-title" style="margin-top: 20px;">2. Yêu cầu đặc biệt (Tùy chọn)</h4>
                <div class="input-group" style="margin-bottom: 30px;">
                    <textarea asp-for="GhiChu" rows="3" placeholder="Nhập ghi chú thêm của bạn(Không bắt buộc)"></textarea>
                    <small style="color: #888; font-size: 0.8rem; margin-top: 5px; display: block;">* Các yêu cầu này sẽ được khách sạn sắp xếp tùy thuộc vào tình trạng phòng.</small>
                </div>

                <!-- SECTION 3: Hóa đơn tạm tính -->
                <div class="receipt-box">
                    <div class="receipt-row">
                        <span>Giá phòng (<span id="night-count">0</span> đêm):</span>
                        <span id="calc-room-price">0 ₫</span>
                    </div>
                    <div class="receipt-row" style="color: #28a745;">
                        <span>Thuế & Phí dịch vụ:</span>
                        <span>Đã bao gồm</span>
                    </div>
                    <div class="receipt-row receipt-total">
                        <span>Tổng thanh toán:</span>
                        <span id="calc-total-price" style="color: #dc3545;">0 ₫</span>
                    </div>
                </div>

                <button asp-controller="Booking" asp-action="ConfirmBook" type="submit" class="btn-submit">
                    XÁC NHẬN ĐẶT PHÒNG NGAY <i class="fas fa-arrow-right" style="margin-left: 10px;"></i>
                </button>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" /> @* Nạp script để bắt lỗi đỏ ngay tại client *@
    <script>
        // JS XỬ LÝ TÍNH TIỀN REALTIME (BIÊN LAI ĐIỆN TỬ)
        const checkInInput = document.getElementById('checkIn');
        const checkOutInput = document.getElementById('checkOut');

        const pricePerNight = parseInt(document.getElementById('price-per-night').getAttribute('data-price')) || 0;

        const nightCountDisplay = document.getElementById('night-count');
        const calcRoomPriceDisplay = document.getElementById('calc-room-price');
        const calcTotalPriceDisplay = document.getElementById('calc-total-price');

        // Hàm định dạng tiền tệ VNĐ
        function formatVND(amount) {
            return amount.toLocaleString('vi-VN') + " ₫";
        }

        function calculateTotal() {
            if (checkInInput.value && checkOutInput.value) {
                const date1 = new Date(checkInInput.value);
                const date2 = new Date(checkOutInput.value);

                // Reset giờ về 0 để tính số ngày chính xác
                date1.setHours(0,0,0,0);
                date2.setHours(0,0,0,0);

                const diffTime = date2 - date1;
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                if (diffDays > 0) {
                    const total = diffDays * pricePerNight;

                    // Cập nhật giao diện biên lai
                    nightCountDisplay.innerText = diffDays;
                    calcRoomPriceDisplay.innerText = formatVND(total);
                    calcTotalPriceDisplay.innerText = formatVND(total);

                    // Bật lại nút submit nếu bị tắt
                    document.querySelector('.btn-submit').disabled = false;
                    document.querySelector('.btn-submit').style.opacity = '1';

                } else {
                    // Cảnh báo nếu ngày trả trước ngày nhận
                    nightCountDisplay.innerText = 0;
                    calcRoomPriceDisplay.innerText = "Ngày không hợp lệ";
                    calcRoomPriceDisplay.style.color = "red";
                    calcTotalPriceDisplay.innerText = "0 ₫";

                    // Khóa nút submit
                    document.querySelector('.btn-submit').disabled = true;
                    document.querySelector('.btn-submit').style.opacity = '0.5';
                }
            }
        }

        checkInInput.addEventListener('change', calculateTotal);
        checkOutInput.addEventListener('change', calculateTotal);

        // Đặt giới hạn ngày check-in không được chọn trong quá khứ
        const today = new Date().toISOString().split('T')[0];
        checkInInput.setAttribute('min', today);
        checkOutInput.setAttribute('min', today);
    </script>
}