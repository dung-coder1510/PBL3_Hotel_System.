@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model PBL3_Hotel_System.ViewModels.DashboardViewModel
@{
    Layout = "_KHDashboardLayout"; // Sử dụng layout chung
    ViewData["Title"] = "Bảng điều khiển";
    ViewData["ActiveMenu"] = "Dashboard";
}
@using System.Security.Claims
@{
    // 1. Lấy tên người dùng từ Identity (thông thường là Username)
    // Nếu bạn muốn lấy Họ tên thật, hãy đảm bảo lúc Đăng nhập bạn đã lưu nó vào ClaimTypes.Name
    var fullName = User.Identity.IsAuthenticated ? User.Identity.Name : "Khách hàng";

    // 2. (Tùy chọn) Nếu bạn muốn lấy một thông tin khác trong Claim
    // var email = User.FindFirst(ClaimTypes.Email)?.Value;
}

            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                <div>
                    <h2 style="font-family: 'Playfair Display', serif; font-size: 2.2rem;">Xin chào, @Model.TenKhachHang!</h2>
                    <p style="color: var(--text-light)">Hôm nay bạn muốn trải nghiệm căn phòng nào?</p>
                </div>
                <a asp-controller="Room" asp-action="Index" class="btn-gold">
                    <i class="fas fa-plus"></i> Đặt phòng mới
                </a>
            </div>

            <!-- KHU VỰC STATS - PHẢI ĐÚNG CẤU TRÚC NÀY ĐỂ HIỆN HÀNG NGANG -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-bed"></i></div>
                    <div class="stat-info">
                        <h4>Phòng đã đặt</h4>
                        <span>@Model.TotalBookings</span>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-gem"></i></div>
                    <div class="stat-info">
                        <h4>Hạng thành viên</h4>
                        <span>@Model.MemberRank</span>
                    </div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-coins"></i></div>
                    <div class="stat-info">
                        <h4>Điểm tích lũy</h4>
                        <span>@Model.TotalPoints.ToString("N0")</span>
                    </div>
                </div>
            </div>

            <!-- KHU VỰC BẢNG LỊCH SỬ GIAO DỊCH -->
            <div class="content-card" style="margin-top: 30px;">
                <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="font-family: var(--font-heading); color: var(--secondary-color);">Giao dịch gần đây</h3>
        
                    <!-- Nút Xem tất cả dẫn sang trang MyHistory -->
                    <a asp-controller="KhachHang" asp-action="MyHistory" style="font-size: 0.95rem; color: var(--primary-color); font-weight: 600; text-decoration: none;">
                        Xem tất cả lịch sử <i class="fas fa-angle-right"></i>
                    </a>
                </div>

                <!-- PHÉP MÀU NẰM Ở ĐÂY: Chỉ cần 1 dòng này để gọi toàn bộ cái bảng (dùng chung) -->
                <partial name="_TransactionTablePartial" model="Model.RecentBookings" />
            </div>

